# =============================================================================
# bulmaca777.com — CANLI SUNUCU (/opt/bulmaca777/.env)
# Kurulum: cp .env.production.example .env  →  Google satirlarini doldur  →  restart
# =============================================================================

# --- Sunucu ---
PORT=3847
HOST=0.0.0.0
PUBLIC_URL=https://bulmaca777.com

NODE_ENV=production
COOKIE_SECURE=true

# --- Sohbet (InnerChat) ---
# youtube = canli yayin linki + youtube-chat (OAuth sohbet okuma icin GEREKMEZ)
# mock = sadece panel testi
CHAT_MODE=youtube

# --- Google OAuth (yalnizca panele giris) ---
GOOGLE_CLIENT_ID=BURAYA_CLIENT_ID
GOOGLE_CLIENT_SECRET=BURAYA_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://bulmaca777.com/auth/callback

# Canli yayin linki: Admin → Sohbet botu → her oda ayri (buraya yazilmaz)

# --- Oyun / bot (oda ayari da degistirebilir) ---
WIN_MESSAGE=Tebrikler {user}! Dogru cevap: {answer}
NEXT_QUESTION_DELAY_MS=5000
# Son bilen ekranda kalir (1=acik, 0=5sn sonra gecis)
HOLD_WINNER_UNTIL_NEXT=1

# --- Ucretli yas / overlay ---
PUZZLE_FEED_MAX=7
CELEBRITY_CLOSE_YEARS=2
CELEBRITY_WARM_YEARS=5
BROADCAST_HOLD_MS=6500
CELEBRITY_CORRECT_FLASH_MS=5000
CELEBRITY_PR_ROTATE_MS=5500
CELEBRITY_PRIZE_LABEL=EN YUKSEK PUANA ODUL VAR!

# --- InnerChat / sohbet kaliciligi ---
YOUTUBE_CHAT_STAY_CONNECTED=1
YOUTUBE_CHAT_KEEPALIVE_MS=45000
INNER_CHAT_POLL_MS=5000
INNER_CHAT_ERROR_BACKOFF_MS=15000
WRONG_BROADCAST_HOLD_MS=5000
WRONG_BROADCAST_QUEUE_MAX=15

# --- InnerChat / denetim (test & VPS tanilama) ---
INNER_CHAT_TAP=1
INNER_CHAT_DEBUG=1

# VPS: YouTube onay / bot duvari (InnerChat tanı için)
# YOUTUBE_CONSENT_COOKIE=CONSENT=YES+1
# veya tarayicidan youtube.com cookie export (SOCS, VISITOR_INFO1_LIVE, ...)
# YOUTUBE_FETCH_LANG=tr-TR,tr;q=0.9,en-US;q=0.8,en;q=0.7
# Datacenter IP kisitliysa residential proxy:
# YOUTUBE_HTTP_PROXY=http://user:pass@host:port
AUDIT_LOG=1
AUDIT_LOG_PERSIST=1
AUDIT_LOG_CONSOLE=1

# --- Oyun alani (kapali = /play/ 404) ---
# PLAYGROUND=0

# =============================================================================
# ASAGIDAKILER InnerChat icin KULLANILMAZ (eski OAuth API sohbet modu)
# InnerChat acikken silinebilir veya yorumda birakilabilir — zarar vermez.
# =============================================================================
# YOUTUBE_MIN_POLL_MS=10000
# YOUTUBE_MAX_POLL_MS=12000
# YOUTUBE_IDLE_POLL_MS=45000
# YOUTUBE_QUIET_POLL_MS=20000
# YOUTUBE_LIVE_CHECK_EVERY_POLLS=60
# YOUTUBE_LIVE_CHECK_QUIET_SEC=180
# YOUTUBE_POLL_IN_WINNER=off
# YOUTUBE_WELCOME_ON_CONNECT=off
# YOUTUBE_ANNOUNCE_GAME_START=off
# YOUTUBE_QUOTA_PAUSE_MS=900000
# YOUTUBE_CHANNEL_CACHE_MS=21600000
# YOUTUBE_DAILY_QUOTA_LIMIT=10000
