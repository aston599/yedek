# =============================================================================
# Bulmaca777 — ortam degiskenleri (.env)
# Kopyala: cp .env.example .env  sonra degerleri doldur.
# =============================================================================

# --- Sunucu ---
PORT=3847
# 0.0.0.0 = disaridan erisim (VPS/Docker). localhost sadece yerel test.
HOST=0.0.0.0

# Panel, overlay ve OAuth linkleri icin tam adres (sonunda / olmasin)
PUBLIC_URL=http://localhost:3847
# Canli ornek: PUBLIC_URL=https://bulmaca777.com

# PUBLIC_URL yoksa kullanilir (genelde gerekmez)
# PUBLIC_HOST=bulmaca777.com

# --- Ortam ---
# production = HTTPS cerezleri varsayilan acik (auth.js)
NODE_ENV=development
# Canli: NODE_ENV=production

# true = oturum cerezi sadece HTTPS (canli sitede zorunlu)
# COOKIE_SECURE=true

# --- YouTube sohbet ---
# youtube = canli video ID ile okuma (youtube-chat, API kotasi yok) | mock = sadece panel testi
CHAT_MODE=youtube

# InnerChat ham mesaj tap (admin panelde canli liste). Kapatmak icin: INNER_CHAT_TAP=0
# INNER_CHAT_TAP=1

# VPS tanilama: journalctl'ta [InnerChat ODA_ID] satirlari. Acik: INNER_CHAT_DEBUG=1
# INNER_CHAT_DEBUG=0

# Denetim gunlugu (admin panel + journalctl [Audit]). Kapatmak: AUDIT_LOG=0
# AUDIT_LOG=1
# AUDIT_LOG_PERSIST=1
# AUDIT_LOG_CONSOLE=1

# Dogru bilenler overlay listesi (3-20, varsayilan 7)
# PUZZLE_FEED_MAX=10

# --- Google Cloud (OAuth 2.0 + YouTube Data API v3) ---
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3847/auth/callback
# Canli (bulmaca777.com):
# GOOGLE_REDIRECT_URI=https://bulmaca777.com/auth/callback

# OAuth token: data/rooms/{odaId}/tokens.json (otomatik, .env'de degil)
# Canli yayin video linki: panelde oda basina (Sohbet botu)

# --- Oyun / bot varsayilanlari (oda ayarindan da degisir) ---
# Sablon degiskenleri: {user} {answer} {question} {bot}
WIN_MESSAGE=Tebrikler {user}! Dogru cevap: {answer}

# Dogru cevaptan sonra sonraki soruya gecis (milisaniye)
NEXT_QUESTION_DELAY_MS=5000

# --- YouTube API kota (gunluk ~10.000 birim / GCP projesi, tum odalar paylasir) ---
# liveChatMessages.list = 5 | insert (bot mesaji) = 50 | videos.list = 1 | channels.list = 1
# YOUTUBE_DAILY_QUOTA_LIMIT=10000

# Oyun aktifken minimum poll (ms). Varsayilan 10 sn.
YOUTUBE_MIN_POLL_MS=10000
# Ust sinir — API 5 sn dese bile (varsayilan 12 sn)
YOUTUBE_MAX_POLL_MS=12000
# Sessiz sohbette yavaslama tabani (ms, varsayilan 20 sn)
YOUTUBE_QUIET_POLL_MS=20000

# Yayin bitti mi: kac AKTIF poll'da bir videos.list (varsayilan 60 ≈ 10 dk @10sn)
YOUTUBE_LIVE_CHECK_EVERY_POLLS=60
# Son 3 dk sohbet geldiyse videos.list atla
# YOUTUBE_LIVE_CHECK_QUIET_SEC=180
# Kazanan ekraninda da oku: on | off (varsayilan off)
# YOUTUBE_POLL_IN_WINNER=off

# Baglaninca karsilama: off (varsayilan) | short | full — her mesaj 50 birim
YOUTUBE_WELCOME_ON_CONNECT=off
# Bulmaca baslayinca sohbete duyuru: on | off (varsayilan off, 50 birim)
YOUTUBE_ANNOUNCE_GAME_START=off

# Kota asilinca API + polling duraklatma (ms, varsayilan 15 dk)
YOUTUBE_QUOTA_PAUSE_MS=900000

# Kanal profili onbellek (ms, varsayilan 6 saat) — API test / yenile kotasi
YOUTUBE_CHANNEL_CACHE_MS=21600000

# --- Opsiyonel ---
# APP_VERSION=1.0.0
# STARTED_AT=
